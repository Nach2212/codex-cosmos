    <script>
        let scene, camera, renderer, particles, sun, corona;
        const container = document.getElementById('canvas-container');

        function init3D() {
            scene = new THREE.Scene();
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.z = 5;

            renderer = new THREE.WebGLRenderer({ antialias: true, alpha: true });
            renderer.setPixelRatio(window.devicePixelRatio);
            renderer.setSize(window.innerWidth, window.innerHeight);
            container.appendChild(renderer.domElement);

            const sunGeom = new THREE.IcosahedronGeometry(1.6, 12);
            const sunMat = new THREE.MeshBasicMaterial({ 
                color: 0x00f2ff, wireframe: true, transparent: true, opacity: 0.12 
            });
            sun = new THREE.Mesh(sunGeom, sunMat);
            scene.add(sun);

            const coronaGeom = new THREE.TorusGeometry(2.3, 0.012, 16, 100);
            const coronaMat = new THREE.MeshBasicMaterial({ color: 0x00f2ff, transparent: true, opacity: 0.04 });
            corona = new THREE.Mesh(coronaGeom, coronaMat);
            scene.add(corona);

            const particleGeom = new THREE.BufferGeometry();
            const count = 18000;
            const posArray = new Float32Array(count * 3);
            for(let i = 0; i < count * 3; i+=3) {
                const angle = Math.random() * Math.PI * 2;
                const radius = 3 + Math.random() * 35;
                posArray[i] = Math.cos(angle) * radius;
                posArray[i+1] = Math.sin(angle) * radius;
                posArray[i+2] = (Math.random() - 0.5) * 100;
            }
            particleGeom.setAttribute('position', new THREE.BufferAttribute(posArray, 3));
            const particleMat = new THREE.PointsMaterial({ 
                size: 0.02, color: 0x00f2ff, transparent: true, opacity: 0.7, blending: THREE.AdditiveBlending 
            });
            particles = new THREE.Points(particleGeom, particleMat);
            scene.add(particles);

            animate();
        }

        function animate() {
            requestAnimationFrame(animate);
            const scrollPerc = window.scrollY / (document.documentElement.scrollHeight - window.innerHeight);
            
            sun.rotation.y += 0.003;
            sun.rotation.z += 0.001;
            corona.rotation.x += 0.015;
            particles.rotation.z += 0.0002;

            const pos = particles.geometry.attributes.position.array;
            for(let i = 2; i < pos.length; i+=3) {
                pos[i] += 0.03 + (scrollPerc * 1.5);
                if(pos[i] > 5) pos[i] = -95;
            }
            particles.geometry.attributes.position.needsUpdate = true;

            camera.position.z = 5 - (scrollPerc * 3.5);
            const s = 1 + (scrollPerc * 14);
            sun.scale.set(s, s, s);

            if (scrollPerc > 0.9) {
                particles.material.color.setHex(0xffffff);
                sun.material.color.setHex(0xffffff);
            } else {
                particles.material.color.setHex(0x00f2ff);
                sun.material.color.setHex(0x00f2ff);
            }

            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        function triggerUpload(element) {
            const input = document.createElement('input');
            input.type = 'file';
            input.accept = 'image/*';
            input.onchange = e => {
                const file = e.target.files[0];
                const reader = new FileReader();
                reader.onload = event => {
                    element.innerHTML = `<img src="${event.target.result}" class="animate-pulse" />`;
                    element.classList.add('has-image');
                };
                reader.readAsDataURL(file);
            };
            input.click();
        }

        document.querySelectorAll('[contenteditable="true"]').forEach(el => {
            el.addEventListener('blur', () => {
                const note = document.getElementById('save-status');
                note.style.opacity = '1';
                setTimeout(() => note.style.opacity = '0', 3000);
            });
        });

        window.onload = init3D;
    </script>
